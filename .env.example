# MarginGuard safe local defaults.
#
# Live Add Collateral signing is disabled unless this value is exactly lowercase "true".
# Only set VITE_ENABLE_LIVE_ADD_COLLATERAL=true for controlled manual QA with:
# - a user-controlled action-needed Mainnet manager;
# - a small amount acceptable to lose;
# - manager ID, wallet, amount, network, and asset verified in Transaction Review and wallet.

VITE_SUI_NETWORK=mainnet
VITE_SUI_FULLNODE_URL=
VITE_ENABLE_LIVE_ADD_COLLATERAL=false
